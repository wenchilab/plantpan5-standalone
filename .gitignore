# Build artifacts -- populated by build.sh from ../program_base/.
# Kept OUT of the public repo: distribution is via package.sh zip / Docker
# image, not git. The repo ships code only, never the bundled libraries.
/bin/match
/data/PlantPAN3_v2_matrix_with_TF.dat
/data/PlantPAN3_v2_matrix_with_TF.dat.minFP.prf
/data/motif_family.json
/data/pattern_seq_uniprot_place.dat
/data/pattern_seq_uniprot_place.dat.minFP.prf
/data/place_meta.json

# Extension libraries are user/runtime data (or bundled at build time from a
# private source) — never part of the public code repo.
/data/libraries/

# Internal development notes / planning docs — NOT for the public repo.
# These stay on the dev machine only. End users get README.md + OFFLINE_BUILD.md.
/GUIDE.md
/NEXT_FEATURE_PROMPT.md
/NEXT_FEATURE_PROMPT_v2.md
/REPACKAGE_INSTRUCTIONS.md
/DESIGN_extensible_motif_library.md
/RELEASE.md

# Maintainer-only build tooling — these name the curated source files, so they
# must never reach the public repo or a distribution zip. Public users get the
# payload pre-built in the self-contained zip / image.
/scripts/_dev_make_payload.sh
/scripts/extract_motif_family.php
/scripts/extract_motif_family.py
/scripts/extract_place_meta.php
/scripts/extract_place_meta.py

# OS / Editor
.DS_Store
*.swp
__pycache__/
